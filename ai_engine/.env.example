# AI Engine Environment Variables (.env.example)

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
DATABASE_URL_SUPABASE=postgresql+psycopg://postgres:password@db.supabase.co:5432/postgres

# AI Engine Configuration
AI_ENGINE_PORT=8001
AI_ENGINE_TOKEN=dev-secret-key-change-in-production

# OpenAI API (for LLM-based NLP services)
OPENAI_API_KEY=sk-...

# Debug Mode
DEBUG=False

# Logging
LOG_LEVEL=INFO
