# Root-Level Environment Variables (.env.example)
# Copy this file to .env and fill in your actual values.
# Each service loads its own subset of these variables.

# ============================================================================
# FRONTEND CONFIGURATION (port 3000)
# ============================================================================
VITE_API_URL=http://localhost:8000

# ============================================================================
# BACKEND CONFIGURATION (port 8000)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
DATABASE_URL_SUPABASE=postgresql+psycopg://postgres:password@db.supabase.co:5432/postgres

# Backend calls AI Engine on port 8001 with shared secret token
AI_ENGINE_URL=http://localhost:8001
AI_ENGINE_TOKEN=dev-secret-key-change-in-production

BACKEND_PORT=8000
DEBUG=False

# ============================================================================
# AI ENGINE CONFIGURATION (port 8001)
# ============================================================================
# Same Supabase credentials (both services read from same DB)
# NOTE: SUPABASE_URL and SUPABASE_KEY should match Backend values above

# OpenAI API Key (required for LLM-based NLP services in AI Engine)
OPENAI_API_KEY=sk-...

# Shared secret token - MUST match AI_ENGINE_TOKEN above
AI_ENGINE_PORT=8001

DEBUG=False
